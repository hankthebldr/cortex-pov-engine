{
  "manifest_version": 3,
  "name": "AI Page Summarizer",
  "description": "Summarises any web page with one click. CORTEXSIM-CANARY artifact.",
  "version": "0.0.1",
  "permissions": [
    "tabs",
    "cookies",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
