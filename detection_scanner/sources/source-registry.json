{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "registry_version": "1.1.0",
  "description": "Indexed threat-intel and execution-framework sources for the cortex-pov-engine TTP corpus. Consumed by the cortex-scraper to crawl, parse, and emit candidate TTP drafts. Tier 1 = primary/canonical; Tier 2 = vendor intel; Tier 3 = government; Tier 4 = IR/community; Tier 5 = execution frameworks (payload sources, not intel).",
  "updated_at": "2026-05-13",
  "sources": [
    {
      "id": "SRC-UNIT42",
      "name": "Unit 42 \u2014 Palo Alto Networks",
      "tier": 1,
      "weight": 1.0,
      "publisher_class": "vendor-internal",
      "homepage": "https://unit42.paloaltonetworks.com/",
      "blog_index": "https://unit42.paloaltonetworks.com/category/threat-research/",
      "feeds": [
        {
          "type": "rss",
          "url": "https://unit42.paloaltonetworks.com/feed/"
        }
      ],
      "scrape_hints": {
        "article_selector": "article.post, .post-content",
        "title_selector": "h1.entry-title",
        "date_selector": "time.entry-date",
        "tag_selector": ".post-tags a, .tag-links a",
        "extract_ioc_section": true,
        "extract_atomic_indicators_table": true,
        "follow_internal_links": true
      },
      "actor_taxonomy_alias": {
        "naming_convention": "Constellation (Libra/Aquila/etc.)",
        "examples": [
          "Muddled Libra",
          "Scattered Spider (== Muddled Libra alias)",
          "Bling Libra",
          "Howling Scorpius"
        ]
      },
      "rate_limit_rpm": 30,
      "categories_of_interest": [
        "threat-research",
        "malware",
        "ransomware",
        "incident-response",
        "cloud",
        "identity",
        "vulnerabilities"
      ],
      "primary": true,
      "update_cadence": "weekly",
      "discovery_queries": [
        "Unit 42 threat assessment {actor}",
        "Unit 42 ransomware kill chain {year}",
        "Unit 42 cloud IAM threat research",
        "Unit 42 incident response report {year}",
        "Unit 42 anatomy of an attack",
        "Unit 42 threat bulletin {month} {year}"
      ],
      "last_canvassed": null
    },
