  "scraper_contract": {
    "scraper_name": "cortex-scraper",
    "input_path": "sources/source-registry.json",
    "output_path": "ttps/_drafts/",
    "draft_status": "draft",
    "draft_filename_pattern": "TTP-{YYYY}-{NNNN}-{slug}.json",
    "draft_review_required": true,
    "rate_limit_global_rpm": 60,
    "cache_dir": ".cache/scraper/",
    "notes": "Drafts land in ttps/_drafts/ with status=draft. A human reviewer promotes them to ttps/ with status=active after schema validation and Cortex-specific field enrichment (IOCs, BIOCs, product mapping, use cases)."
  }
}
